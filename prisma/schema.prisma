generator client {
  provider = "prisma-client-id-pk"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                String              @id @default(cuid()) @db.VarChar(255)
  reference         String              @unique @db.VarChar(255)
  designation       String
  range             RangeType
  sellingPrice      Decimal?            @default(0.00) @db.Decimal(10, 2)
  imageUrl          String?
  description       String?
  createdAt         DateTime            @default(now()) @db.Timestamp(6)
  updatedAt         DateTime            @default(now()) @updatedAt @db.Timestamp(6)
  BOM               BOM[]
  Document          Document[]
  ManufacturingStep ManufacturingStep[]
}

model BOM {
  id          String     @id @db.VarChar(255)
  productId   String?    @db.VarChar(255)
  componentId String?    @db.VarChar(255)
  quantity    Decimal    @default(1.00) @db.Decimal(10, 2)
  Component   Component? @relation(fields: [componentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Product     Product?   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Component {
  id         String    @id @db.VarChar(255)
  reference  String?   @db.VarChar(255)
  name       String
  unitPrice  Decimal?  @default(0.00) @db.Decimal(10, 2)
  supplierId String?   @db.VarChar(255)
  BOM        BOM[]
  Supplier   Supplier? @relation(fields: [supplierId], references: [id], onUpdate: NoAction)
}

model Document {
  id         String   @id @db.VarChar(255)
  productId  String?  @db.VarChar(255)
  type       DocType
  title      String   @db.VarChar(255)
  fileUrl    String
  version    String?  @default("1.0") @db.VarChar(50)
  uploadedAt DateTime @default(now()) @db.Timestamp(6)
  Product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ManufacturingStep {
  id            String   @id @db.VarChar(255)
  productId     String?  @db.VarChar(255)
  stepOrder     Int
  name          String   @db.VarChar(255)
  instructions  String?
  photoUrl      String?
  estimatedTime Decimal? @default(0.00) @db.Decimal(10, 2)
  hourlyRate    Decimal? @default(50.00) @db.Decimal(10, 2)
  Product       Product? @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Setting {
  key         String  @id @db.VarChar(255)
  value       String  @db.VarChar(255)
  description String?
}

model Supplier {
  id           String      @id @db.VarChar(255)
  name         String      @db.VarChar(255)
  contactEmail String?     @db.VarChar(255)
  Component    Component[]
}

enum RangeType {
  HST
  VST
  VSTL
}

enum DocType {
  PLAN_FAB
  PLAN_ECLATE
  PROCEDURE
}
